enum UserRole {
    USER
    ADMIN
    MODERATOR
}

enum UserStatus {
    ONLINE
    OFFLINE
    AWAY
    BUSY
    INVISIBLE
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

model User {
    id          String @id @default(uuid())
    username    String @unique @db.VarChar(50)
    displayName String @map("display_name") @db.VarChar(100)
    password    String @db.VarChar(255)
    phone       String @unique @db.VarChar(10)

    dateOfBirth DateTime @map("date_of_birth")
    gender      Gender   @default(MALE)

    role         UserRole   @default(USER)
    status       UserStatus @default(OFFLINE)
    lastActiveAt DateTime?  @updatedAt @map("last_active_at")
    socketId     String?    @map("socket_id")

    // Profile
    avatarUrl   String?   @default("https://avatar.iran.liara.run/public") @map("avatar_url")
    bio         String?   @db.Text
    isVerified  Boolean   @default(false) @map("is_verified")
    isBanned    Boolean   @default(false) @map("is_banned")
    bannedUntil DateTime? @map("banned_until")

    // Địa chỉ Việt Nam + vị trí realtime
    addressStreet   String?  @map("address_street") @db.VarChar(255)
    addressWard     String?  @map("address_ward") @db.VarChar(100)
    addressDistrict String?  @map("address_district") @db.VarChar(100)
    addressCity     String?  @map("address_city") @db.VarChar(100)
    addressCountry  String?  @default("Việt Nam") @map("address_country")
    latitude        Decimal? @db.Decimal(10, 8)
    longitude       Decimal? @db.Decimal(11, 8)

    // Privacy - quyền hiển thị
    onlineStatusVisibility String @default("everyone") @map("online_status_visibility")
    lastSeenVisibility     String @default("friends") @map("last_seen_visibility")
    profileVisibility      String @default("everyone") @map("profile_visibility")
    locationVisibility     String @default("friends") @map("location_visibility")

    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    // Relations
    sentMessages Message[]    @relation("MessageSender")
    rooms        RoomMember[]
    friends      UserFriend[] @relation("UserFriends")
    friendedBy   UserFriend[] @relation("FriendedBy")

    blockedUsers Block[] @relation("Blocker")
    blockedBy    Block[] @relation("Blocked")

    typingIn     Typing[]
    readReceipts ReadReceipt[]
    reactions    Reaction[]
    devices      UserDevice[]

    @@index([username])
    @@index([status])
    @@index([lastActiveAt])
    @@index([addressCity])
    @@index([latitude, longitude])
    @@map("users")
}
