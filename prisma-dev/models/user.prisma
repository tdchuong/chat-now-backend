enum UserRole {
    USER
    ADMIN
    MODERATOR
}

enum UserStatus {
    ONLINE
    OFFLINE
    AWAY
    BUSY
    INVISIBLE
}

model User {
    id           String  @id @default(uuid())
    username     String  @unique @db.VarChar(50)
    display_name String? @db.VarChar(100)
    password     String  @db.VarChar(255)

    role           UserRole   @default(USER)
    status         UserStatus @default(OFFLINE)
    last_active_at DateTime?  @updatedAt
    socket_id      String?

    // Profile
    avatar_url   String?   @default("https://avatar.iran.liara.run/public")
    bio          String?   @db.Text
    is_verified  Boolean   @default(false)
    is_banned    Boolean   @default(false)
    banned_until DateTime?

    // Địa chỉ Việt Nam + vị trí realtime
    address_street   String?  @db.VarChar(255)
    address_ward     String?  @db.VarChar(100)
    address_district String?  @db.VarChar(100)
    address_city     String?  @db.VarChar(100)
    address_country  String?  @default("Việt Nam")
    latitude         Decimal? @db.Decimal(10, 8)
    longitude        Decimal? @db.Decimal(11, 8)

    // Privacy Quyền hiển thị
    online_status_visibility String @default("everyone") // trạng thái trực tuyến:
    last_seen_visibility     String @default("friends") // lần truy cập cuối:
    profile_visibility       String @default("everyone") // hồ sơ cá nhân:
    location_visibility      String @default("friends") //  vị trí:

    created_at DateTime  @default(now())
    updated_at DateTime  @updatedAt
    deleted_at DateTime?

    // Relations
    sent_messages Message[]     @relation("MessageSender")
    rooms         RoomMember[]
    friends       UserFriend[]  @relation("UserFriends")
    friended_by   UserFriend[]  @relation("FriendedBy")
    blocked_users Block[]       @relation("Blocker")
    blocked_by    Block[]       @relation("Blocked")
    typing_in     Typing[]
    read_receipts ReadReceipt[]
    reactions     Reaction[]

    @@index([username])
    @@index([status])
    @@index([last_active_at])
    @@index([address_city])
    @@index([latitude, longitude])
    @@map("users")
}
