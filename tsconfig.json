{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@modules/*": [
        "src/modules/*"
      ],
      "@configs/*": [
        "src/configs/*"
      ],
      "@repositories/*": [
        "src/repositories/*"
      ],
       "@common/*": ["src/common/*"]  // Đảm bảo alias này đã được cấu hình

    },
  }
}
